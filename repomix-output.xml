CREATE OR REPLACE VIEW secure_catalog AS
  SELECT 
    id, 
    name, 
    brand, 
    size, 
    price_public, 
    stock, 
    category, 
    barcode, 
    description, 
    image_url,
    -- Mostrar precio promocional (VIP) solo a usuarios autenticados
    CASE 
