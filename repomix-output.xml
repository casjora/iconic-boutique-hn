          body, html, #root {
            background-color: white !important;
            color: black !important;
            margin: 0 !important;
            padding: 0 !important;
            height: auto !important;
            min-height: 0 !important;
          }
          
          main {
            max-width: none !important;
            padding: 0 !important;
            margin: 0 !important;
